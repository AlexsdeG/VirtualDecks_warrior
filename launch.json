      },
      {
          "name": "Launch Program (Linux)",
          "type": "cppdbg",
          "request": "launch",
          "program": "${workspaceFolder}/build/bin/JUCE Loop Station",
          "args": [],
          "cwd": "${workspaceFolder}",
          "stopAtEntry": false,
          "preLaunchTask": "build",
          "MIMode": "gdb",
          "setupCommands": [
              {
                  "description": "Enable pretty-printing for gdb",
                  "text": "-enable-pretty-printing",
                  "ignoreFailures": true
              }
          ]
      }
    ]
