{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CMake: Debug App",
            "type": "cppdbg", // NICHT "cmake"
            "request": "launch",
            "projectRoot": "${workspaceFolder}",
            "nativeDebuggerCategory": "DEBUG",
            "parameter": [],
            "program": "${command:cmake.launchTargetPath}", 
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "$PATH:${command:cmake.getLaunchTargetDirectory}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
